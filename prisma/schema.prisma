generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique // I changed 'Email' to 'email' (standard convention)
  password String  // I changed 'Password' to 'password'
  name     String?
}